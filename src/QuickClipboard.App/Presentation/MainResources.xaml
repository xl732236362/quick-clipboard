<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="PanelBackgroundColor">#F21F1F1F</Color>
    <Color x:Key="PanelTextColor">#F5F5F5</Color>
    <Color x:Key="PanelMutedTextColor">#B8B8B8</Color>
    <Color x:Key="PanelAccentColor">#4CC2FF</Color>
    <Color x:Key="PanelItemHoverColor">#333333</Color>

    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="PanelTextBrush" Color="{StaticResource PanelTextColor}" />
    <SolidColorBrush x:Key="PanelMutedTextBrush" Color="{StaticResource PanelMutedTextColor}" />
    <SolidColorBrush x:Key="PanelAccentBrush" Color="{StaticResource PanelAccentColor}" />
    <SolidColorBrush x:Key="PanelItemHoverBrush" Color="{StaticResource PanelItemHoverColor}" />

    <CornerRadius x:Key="PanelItemCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="PanelButtonCornerRadius">8</CornerRadius>

    <Style x:Key="PanelTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource PanelTextBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="PanelMutedTextBlockStyle"
           BasedOn="{StaticResource PanelTextBlockStyle}"
           TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource PanelMutedTextBrush}" />
    </Style>

    <Style x:Key="PanelActionButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="MinWidth" Value="58" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="10,3" />
        <Setter Property="Margin" Value="0,0,6,0" />
        <Setter Property="Foreground" Value="{StaticResource PanelTextBrush}" />
        <Setter Property="Background" Value="#292929" />
        <Setter Property="BorderBrush" Value="#444444" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource PanelButtonCornerRadius}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource PanelItemHoverBrush}" />
                            <Setter Property="BorderBrush" Value="{StaticResource PanelAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#3D3D3D" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PanelListBoxStyle" TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource PanelTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
    </Style>

    <Style x:Key="PanelListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource PanelItemCornerRadius}"
                            Padding="10">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource PanelItemHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#383838" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
